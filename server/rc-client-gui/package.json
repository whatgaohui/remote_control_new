{
  "name": "rc-client-gui",
  "version": "2.0.0",
  "description": "RC-Client 远程控制客户端 - 桌面版",
  "author": "RC-Team",
  "main": "main.js",
  "scripts": {
    "start": "electron . --no-sandbox",
    "dev": "electron . --no-sandbox --dev",
    "build": "electron-builder --win --dir",
    "build:portable": "electron-builder --win portable"
  },
  "dependencies": {
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.rc.client-gui",
    "productName": "RC-Client",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        { "target": "portable", "arch": ["x64"] },
        { "target": "dir", "arch": ["x64"] }
      ],
      "signAndEditExecutable": false,
      "icon": null,
      "artifactName": "${productName}-${version}-Portable.${ext}"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "package.json"
    ]
  }
}
